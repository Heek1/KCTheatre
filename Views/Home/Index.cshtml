@{
    ViewData["Title"] = "Головна";
}

<div class="py-3">
    @if (User.Identity?.IsAuthenticated == true)
    {
        <p class="page-subtitle">Вітаємо назад, <strong style="color:#276749;">@User.Identity.Name</strong> 👋</p>
        <div class="d-flex gap-2 mb-4">
            <a asp-controller="Home" asp-action="Catalog" class="btn-t-primary text-decoration-none px-4 py-2">
                Перейти до репертуару →
            </a>
        </div>
    }
    else
    {
        <h1 class="page-title">TheatreOnline</h1>
        <p class="page-subtitle">Найкращі вистави та спектаклі. Замовляйте квитки онлайн.</p>
        <a asp-controller="Home" asp-action="Catalog" class="btn-t-primary text-decoration-none px-4 py-2 d-inline-block mb-4">
            Увійти та переглянути вистави →
        </a>
    }
</div>

<hr />

<h5 class="mt-4 mb-3" style="color:#2d3748;">Популярне цього тижня</h5>

<div class="row g-3">
    @{
        var shows = new[]
        {
            ("Гамлет", "Трагедія", "9.1", "3год 15хв"),
            ("Лісова пісня", "Драма", "8.9", "2год 30хв"),
            ("Наталка Полтавка", "Опера", "8.6", "2год 10хв"),
            ("Ревізор", "Комедія", "8.4", "2год 05хв"),
        };
    }
    @foreach (var (title, genre, rating, duration) in shows)
    {
        <div class="col-md-3">
            <div class="t-card p-3 h-100">
                <div class="d-flex justify-content-between align-items-start mb-2">
                    <span class="badge-t">⭐ @rating</span>
                    <small style="color:#a0aec0;">@duration</small>
                </div>
                <h6 class="mt-2 fw-bold">@title</h6>
                <small style="color:#718096;">@genre</small>
                <div class="mt-auto pt-3">
                    <a asp-controller="Home" asp-action="Catalog" class="btn-t-outline text-decoration-none d-block text-center btn-sm">
                        Деталі
                    </a>
                </div>
            </div>
        </div>
    }
</div>
