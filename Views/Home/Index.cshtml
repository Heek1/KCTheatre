@{
    ViewData["Title"] = "Головна";
}

<div class="text-center py-5">
    <h1 style="font-size: 3rem;">🎭 TheatreOnline</h1>
    <p class="lead" style="color: #a08060;">
        Найкращі вистави та спектаклі. Замовляйте квитки будь-де, будь-коли.
    </p>

    @if (User.Identity?.IsAuthenticated == true)
    {
        <p>Вітаємо, <strong style="color: #c9a84c;">@User.Identity.Name</strong>!</p>
        <a asp-action="Catalog" class="btn btn-theatre btn-lg">Перейти до репертуару</a>
    }
    else
    {
        <a asp-action="Catalog" class="btn btn-theatre btn-lg">
            Увійти та переглянути вистави
        </a>
    }
</div>

<hr style="border-color: #2e2010;" />

<h4 class="mb-3">🔥 Популярне цього тижня</h4>
<div class="row g-3">
    @{
        var shows = new[]
        {
        ("Гамлет", "Трагедія", "9.1", "3год 15хв"),
        ("Лісова пісня", "Драма", "8.9", "2год 30хв"),
        ("Наталка Полтавка", "Опера", "8.6", "2год 10хв"),
        ("Ревізор", "Комедія", "8.4", "2год 05хв"),
        };
    }
    @foreach (var (title, genre, rating, duration) in shows)
    {
        <div class="col-md-3">
            <div class="card p-3 h-100">
                <div class="d-flex justify-content-between align-items-start mb-2">
                    <span class="badge badge-rating">⭐ @rating</span>
                    <small style="color: #7a6040;">@duration</small>
                </div>
                <h5 class="mt-2">@title</h5>
                <small style="color: #a08060;">@genre</small>
                <div class="mt-auto pt-3">
                    <a asp-action="Catalog"
                       class="btn btn-outline-warning btn-sm w-100">
                        🎟 Придбати квиток
                    </a>
                </div>
            </div>
        </div>
    }
</div>
