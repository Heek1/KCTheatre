@{
    ViewData["Title"] = "Репертуар";
}

<h1 class="page-title">Репертуар</h1>
<p class="page-subtitle">
    Вітаємо, <strong style="color:#276749;">@User.Identity?.Name</strong>!
    Оберіть виставу та придбайте квиток.
</p>

<div class="row g-3">
    @{
        var catalog = new[]
        {
            ("Гамлет", "Трагедія", "9.1", "Принц Данії мститься за вбивство батька"),
            ("Лісова пісня", "Драма", "8.9", "Поетична драма-феєрія Лесі Українки про кохання та свободу"),
            ("Наталка Полтавка", "Опера", "8.6", "Класична українська опера про вірне кохання"),
            ("Ревізор", "Комедія", "8.4", "Гоголівська сатира на чиновницький світ"),
            ("Три сестри", "Драма", "8.7", "Чехівська розповідь про мрії та буденність"),
            ("Зойчина квартира", "Комедія", "8.1", "Гостра сатира Булгакова на радянський побут"),
            ("Майстер і Маргарита", "Містерія", "9.0", "Містична сага про добро, зло та творчість"),
            ("Тіні забутих предків", "Драма", "8.8", "Епічна карпатська легенда про кохання і трагедію"),
        };
    }
    @foreach (var (title, genre, rating, desc) in catalog)
    {
        <div class="col-md-3">
            <div class="t-card p-3 h-100 d-flex flex-column">
                <div class="d-flex justify-content-between align-items-center mb-2">
                    <span class="badge-t">⭐ @rating</span>
                    <small style="color:#a0aec0;">@genre</small>
                </div>
                <h6 class="fw-bold mb-1">@title</h6>
                <p style="font-size:0.82rem; color:#718096; flex:1;">@desc</p>
                <button class="btn-t-primary w-100 mt-2" style="cursor:pointer;">🎟 Придбати квиток</button>
            </div>
        </div>
    }
</div>
