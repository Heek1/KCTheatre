@{
    ViewData["Title"] = "Профіль";
}

<h1 class="page-title">Профіль</h1>
<p class="page-subtitle">Інформація про ваш акаунт та дані з Keycloak.</p>

<div class="row g-3">
    <div class="col-md-5">
        <div class="t-card p-4">
            <h6 class="fw-bold mb-3" style="color:#2d3748;">Основні дані</h6>
            <hr />
            <p class="mb-2"><span style="color:#718096;">Ім'я:</span> <strong>@User.Identity?.Name</strong></p>

            @foreach (var claim in User.Claims)
            {
                if (claim.Type.Contains("name") || claim.Type.Contains("email"))
                {
                    <p class="mb-2">
                        <span style="color:#718096;">@claim.Type.Split('/').Last():</span>
                        <strong>@claim.Value</strong>
                    </p>
                }
            }

            <hr />
            <a asp-controller="Home" asp-action="Logout" class="btn-t-outline text-decoration-none px-3 py-2 d-inline-block">
                Вийти
            </a>
        </div>
    </div>

    <div class="col-md-7">
        <div class="t-card p-4">
            <h6 class="fw-bold mb-3" style="color:#2d3748;">🔑 Claims з Keycloak</h6>
            <hr />
            <div style="max-height: 340px; overflow-y: auto;">
                <table class="table table-sm" style="font-size:0.8rem;">
                    <thead style="background:#f7fafc;">
                        <tr>
                            <th style="color:#718096;">Тип</th>
                            <th style="color:#718096;">Значення</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var claim in User.Claims)
                        {
                            <tr>
                                <td style="color:#a0aec0; word-break:break-all;">@claim.Type</td>
                                <td style="color:#2d3748;">@claim.Value</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>
