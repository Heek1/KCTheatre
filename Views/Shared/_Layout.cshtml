<!DOCTYPE html>
<html lang="uk">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] — TheatreOnline</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <style>
        * {
            box-sizing: border-box;
        }

        body {
            background-color: #f0f4f8;
            color: #1a202c;
            font-family: 'Segoe UI', sans-serif;
            min-height: 100vh;
        }

        /* ── Sidebar layout ── */
        .layout-wrapper {
            display: flex;
            min-height: 100vh;
        }

        .sidebar {
            width: 220px;
            min-height: 100vh;
            background: #1a202c;
            display: flex;
            flex-direction: column;
            padding: 2rem 1.2rem;
            position: fixed;
            top: 0;
            left: 0;
        }

        .sidebar-brand {
            color: #68d391;
            font-size: 1.3rem;
            font-weight: 800;
            text-decoration: none;
            margin-bottom: 2.5rem;
            display: flex;
            align-items: center;
            gap: 0.5rem;
        }

            .sidebar-brand:hover {
                color: #9ae6b4;
                text-decoration: none;
            }

        .sidebar-nav {
            display: flex;
            flex-direction: column;
            gap: 0.3rem;
            flex: 1;
        }

        .sidebar-link {
            color: #a0aec0;
            text-decoration: none;
            padding: 0.55rem 0.9rem;
            border-radius: 8px;
            font-size: 0.95rem;
            font-weight: 500;
            transition: background 0.15s, color 0.15s;
            display: flex;
            align-items: center;
            gap: 0.6rem;
        }

            .sidebar-link:hover {
                background: #2d3748;
                color: #68d391;
                text-decoration: none;
            }

            .sidebar-link.active {
                background: #276749;
                color: #c6f6d5;
            }

        .sidebar-divider {
            border-color: #2d3748;
            margin: 1rem 0;
        }

        .sidebar-logout {
            color: #fc8181;
            text-decoration: none;
            padding: 0.55rem 0.9rem;
            border-radius: 8px;
            font-size: 0.9rem;
            transition: background 0.15s;
            display: flex;
            align-items: center;
            gap: 0.6rem;
        }

            .sidebar-logout:hover {
                background: #2d3748;
                color: #feb2b2;
                text-decoration: none;
            }

        .sidebar-user {
            color: #e2e8f0;
            font-size: 0.85rem;
            padding: 0.55rem 0.9rem;
            border-radius: 8px;
            background: #2d3748;
            margin-bottom: 0.4rem;
            word-break: break-word;
        }

        /* ── Main content ── */
        .main-content {
            margin-left: 220px;
            padding: 2.5rem 2rem;
            width: 100%;
        }

        /* ── Cards ── */
        .t-card {
            background: #ffffff;
            border: 1px solid #e2e8f0;
            border-radius: 14px;
            box-shadow: 0 1px 6px rgba(0,0,0,.06);
            transition: transform 0.18s, box-shadow 0.18s;
        }

            .t-card:hover {
                transform: translateY(-3px);
                box-shadow: 0 8px 24px rgba(72,187,120,.15);
            }

        /* ── Buttons ── */
        .btn-t-primary {
            background: #276749;
            color: #fff;
            border: none;
            border-radius: 8px;
            font-weight: 600;
            padding: 0.45rem 1.1rem;
        }

            .btn-t-primary:hover {
                background: #22543d;
                color: #fff;
            }

        .btn-t-outline {
            background: transparent;
            color: #276749;
            border: 1.5px solid #276749;
            border-radius: 8px;
            font-weight: 600;
            padding: 0.4rem 1rem;
        }

            .btn-t-outline:hover {
                background: #f0fff4;
                color: #22543d;
            }

        /* ── Badge ── */
        .badge-t {
            background: #276749;
            color: #c6f6d5;
            font-size: 0.8rem;
            padding: 0.3em 0.6em;
            border-radius: 6px;
        }

        /* ── Page header ── */
        .page-title {
            font-size: 1.7rem;
            font-weight: 700;
            color: #1a202c;
            margin-bottom: 0.3rem;
        }

        .page-subtitle {
            color: #718096;
            margin-bottom: 1.5rem;
            font-size: 0.95rem;
        }

        hr {
            border-color: #e2e8f0;
        }

        media (max-width: 768px) {
            .sidebar {
                display: none;
            }

            .main-content {
                margin-left: 0;
                padding: 1rem;
            }
        }
    </style>
</head>
<body>
    <div class="layout-wrapper">

        <!-- Sidebar -->
        <aside class="sidebar">
            <a class="sidebar-brand" asp-controller="Home" asp-action="Index">
                🎭 Theatre
            </a>

            <nav class="sidebar-nav">
                @if (User.Identity?.IsAuthenticated == true)
                {
                    <div class="sidebar-user">👤 @User.Identity.Name</div>
                    <hr class="sidebar-divider" />

                    <a class="sidebar-link" asp-controller="Home" asp-action="Index">Головна</a>
                    <a class="sidebar-link" asp-controller="Home" asp-action="Catalog">Репертуар</a>
                    <a class="sidebar-link" asp-controller="Home" asp-action="Profile">Профіль</a>

                    @if (User.IsInRole("guest"))
                    {
                        <a class="sidebar-link" asp-controller="Home" asp-action="Guest">Гостьова</a>
                    }
                    @if (User.IsInRole("admin"))
                    {
                        <a class="sidebar-link" asp-controller="Home" asp-action="Admin">Адмін</a>
                    }

                    <hr class="sidebar-divider" />
                    <a class="sidebar-logout" asp-controller="Home" asp-action="Logout">Вийти</a>
                }
                else
                {
                    <a class="sidebar-link" asp-controller="Home" asp-action="Index">Головна</a>
                    <hr class="sidebar-divider" />
                    <a class="btn-t-primary text-decoration-none text-center py-2 px-3 d-block"
                       asp-controller="Home" asp-action="Catalog">Увійти</a>
                }
            </nav>
        </aside>

        <!-- Main -->
        <main class="main-content">
            @RenderBody()
        </main>

    </div>
</body>
</html>
