<!DOCTYPE html>
<html lang="uk">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] — TheatreOnline</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <style>
        body { background-color: #0d0d0d; color: #e8dcc8; }
        .navbar { background-color: #1a0a00 !important; }
        .navbar-brand { color: #c9a84c !important; font-weight: bold; font-size: 1.5rem; }
        .nav-link { color: #e8dcc8 !important; }
        .nav-link:hover { color: #c9a84c !important; }
        .btn-theatre { background-color: #c9a84c; color: #0d0d0d; border: none; font-weight: 600; }
        .btn-theatre:hover { background-color: #a8873a; color: #0d0d0d; }
        .card { background-color: #1a1208; border: 1px solid #2e2010; border-radius: 8px; }
        .card:hover { transform: scale(1.03); transition: 0.2s; }
        .badge-rating { background-color: #c9a84c; color: #0d0d0d; font-size: 0.85rem; }
    </style>
</head>
<body>
    <nav class="navbar navbar-expand-lg navbar-dark mb-4">
        <div class="container">
            <a class="navbar-brand" asp-controller="Home" asp-action="Index">🎭 TheatreOnline</a>
            <div class="navbar-nav ms-auto">
                @if (User.Identity?.IsAuthenticated == true)
                {
                    <a class="nav-link" asp-action="Catalog">Репертуар</a>
                    <a class="nav-link" asp-action="Profile">
                        👤 @User.Identity.Name
                    </a>
                    <a class="nav-link" asp-action="Logout">Вийти</a>
                }
                else
                {
                    <a class="nav-link btn btn-theatre btn-sm px-3"
                       asp-action="Catalog">Увійти</a>
                }
            </div>
        </div>
    </nav>
    <div class="container">
        @RenderBody()
    </div>
</body>
</html>
